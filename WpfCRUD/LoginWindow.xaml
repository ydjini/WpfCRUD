<Window x:Class="WpfCRUD.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCRUD"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="LoginWindow" Height="456" Width="512">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <Image Source="Images/icon.jpg" Width="67" Height="67" HorizontalAlignment="Right" Margin="15"/>
        <TextBlock Grid.Row="0"
                   Text="Вход"
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center" 
                   FontSize="28"
                   />
        <TextBlock Grid.Row="1"
                   Text="Заполните логин"
                   />
        <TextBox Grid.Row="1"
                 x:Name="txtLogin"
                 VerticalContentAlignment="Center"
                 Margin="0, 28, 0, 28"/>
        <TextBlock Grid.Row="2"
           Text="Заполните пароль"
           />
        <PasswordBox Grid.Row="2"
                 x:Name="txtPassword"
                 VerticalContentAlignment="Center"
                 FontSize="16"
                 Margin="0, 28, 0, 28"
                 />
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
        <Button Grid.Column="0"
                Content="Войти"
                FontSize="16"
                Background="#7FFF00"
                Margin="0, 20, 20, 20"
                Click="LoginButton_Click"
                />
        <Button Grid.Column="1"
                FontSize="16"
                Content="Войти как гость"
                Background="DarkGray"
                Foreground="White"
                Margin="20, 20, 0, 20"
                Click="LoginAsGuestButton_Click"
                />

        </Grid>
    </Grid>
</Window>
