<Window x:Class="WpfCRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCRUD"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="MainWindow" Height="768" Width="1280">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" x:Name="adminPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="67"/>
                <RowDefinition Height="67"/>
                <RowDefinition Height="67"/>
                <RowDefinition Height="67"/>
                <RowDefinition Height="67"/>
                <RowDefinition Height="67"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       x:Name="txtCurrentRole"
                       Text="CurrentRole"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       />
            <Button Grid.Row="1"
                    x:Name="btnMain"
                    Click="btnMain_Click"
                    Content="Главная"
                    FontSize="16"
                    Margin="0 , 16"
                    />
            <Button Grid.Row="2"
                    x:Name="btnOrders"
                    Click="btnOrders_Click"
                    Visibility="Collapsed"
                    Content="Заказы"
                    FontSize="16"
                    Margin="0 , 16"
                    />
            
            <Button Grid.Row="6"
                    VerticalAlignment="Bottom"
                    Click="LogoutButton_Click"
                    Content="Выход"
                    FontSize="16"
                    Background="DarkRed"
                    Foreground="White"
                    Height="42"
                    />
        </Grid>

        <Grid Grid.Column="1" Margin="10" Background="#7FFF00">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" x:Name="ToolsPanel" Background="#7FFF00" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="boxSearch" Margin="8"/>
                <Button Content="Искать" x:Name="btnSearch" Click="btnSearch_Click" Grid.Column="1" Margin="8"/>
                <Button Content="Добавить" Grid.Column="2" Margin="8"/>
            </Grid>
            <ScrollViewer Grid.Row="1" x:Name="dataScrollView" Grid.Column="1">
                <StackPanel x:Name="ProductsContainer" Background="#7FFF00"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
