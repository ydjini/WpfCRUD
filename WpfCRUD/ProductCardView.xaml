<UserControl x:Class="WpfCRUD.ProductCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfCRUD"
             mc:Ignorable="d" 
             d:DesignHeight="220" d:DesignWidth="767">
    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="30, 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="0, 0, 5, 0" BorderBrush="Black" BorderThickness="1"/>
            <Border Grid.Column="1" Margin="0, 0, 5, 0" BorderBrush="Black" BorderThickness="1"/>
            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1"/>
            <Image Grid.Column="0" Source="{Binding ImagePath}" Width="180" Margin="5"/>
            <Grid Grid.Column="1" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontWeight="Bold">
                    <Run Text="{Binding Category.Name}"/>
                    <Run Text=" | "/>
                    <Run Text="{Binding ProductName.Name}"/>
                </TextBlock>
                <TextBlock Grid.Row="1">
                    <Run Text="Описание: "/>
                    <Run Text="{Binding ProductDescription.Name}"/>
                </TextBlock>
                <TextBlock Grid.Row="2">
                    <Run Text="Производитель: "/>
                    <Run Text="{Binding Manufacture.Name}"/>
                </TextBlock>
                <TextBlock Grid.Row="3">
                    <Run Text="Поставщик: "/>
                    <Run Text="{Binding Supplier.Name}"/>
                </TextBlock>
                <TextBlock Grid.Row="4">
                    <Run Text="Цена: "/>
                    <Run Text="{Binding Price}"/>
                    <Run Text=" руб."/>
                </TextBlock>
                <TextBlock Grid.Row="5">
                    <Run Text="Еденица измерения: "/>
                    <Run Text="{Binding UnitName.Name}"/>
                </TextBlock>
                <TextBlock Grid.Row="6">
                    <Run Text="Количество на складе: "/>
                    <Run Text="{Binding Quantity}"/>
                </TextBlock>
            </Grid>
            <TextBlock Grid.Column="2" x:Name="finalPrice" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                <Run Text="{Binding Discount}"/>
                <Run Text=" руб."/>
            </TextBlock>
        </Grid>
        <Grid Grid.Row="1" x:Name="cardBtns" Margin="30, 0, 30, 15" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding Id}" Margin="8" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button Grid.Column="1"
                    Content="Редактировать"
                    Margin="20, 5"
                    Padding="10, 5"
                    />
            <Button Grid.Column="2"
                    Content="Удалить"
                    Click="DeleteCard"
                    Margin="0, 5"
                    Padding="10, 5"
                    Background="DarkRed"
                    Foreground="White"
                    />
        </Grid>
    </Grid>
</UserControl>
